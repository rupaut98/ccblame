{
  "name": "ccblame",
  "version": "0.1.1",
  "description": "git blame for your Claude Code spend — which subagent burned the budget?",
  "type": "module",
  "bin": {
    "ccblame": "dist/cli.mjs"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.3"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "bun src/cli.ts",
    "test": "bun test",
    "lint": "biome check src test",
    "format": "biome check --write src test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "claude",
    "claude-code",
    "subagent",
    "cost",
    "tokens",
    "usage",
    "ccusage",
    "cli"
  ],
  "license": "MIT",
  "author": "rupaut98",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rupaut98/ccblame.git"
  },
  "homepage": "https://github.com/rupaut98/ccblame#readme",
  "bugs": "https://github.com/rupaut98/ccblame/issues",
  "dependencies": {},
  "devDependencies": {
    "@biomejs/biome": "^2.4.0",
    "@types/bun": "^1.3.0",
    "@types/node": "^22.10.0",
    "cli-table3": "^0.6.5",
    "picocolors": "^1.1.1",
    "tsdown": "^0.22.0",
    "typescript": "^5.7.2"
  }
}
